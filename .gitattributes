# 统一换行符:所有文本文件在仓库中以 LF 存储,检出时也用 LF
# 不再依赖各人的 core.autocrlf 设置,避免"无内容差异却显示 modified"的问题
* text=auto eol=lf

# 二进制文件:禁止任何换行符/文本转换
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
